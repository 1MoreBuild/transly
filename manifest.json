{
  "manifest_version": 3,
  "name": "Transly",
  "version": "0.0.1",
  "description": "Article and subtitle translation through a local Codex Native Host.",
  "minimum_chrome_version": "105",
  "key": "",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "permissions": ["activeTab", "nativeMessaging", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Transly",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/article-audit.js", "src/content/article-style.js", "src/content/article-text.js", "src/content/article-progress.js", "src/content/article-batching.js", "src/content/article-placement.js", "src/content/article.js"],
      "css": ["src/content/styles.css"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/subtitle-content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": ["<all_urls>"],
      "resources": ["src/injected/subtitle-hook.js"]
    }
  ]
}
